# Choose one model option by leaving only its MODEL_NAME line uncommented.

# Option 1 — Google Gemini/Gemma API (default)
MODEL_NAME=google:gemma-4-26b-a4b-it
# GEMINI_API_KEY=...

# Option 2 — OpenAI (uncomment these and comment Option 1)
# MODEL_NAME=openai:gpt-4.1-mini
# OPENAI_API_KEY=...

# Option 3 — MiniMax Anthropic-compatible API (uncomment these and comment Option 1)
# MODEL_NAME=anthropic:MiniMax-M3
# ANTHROPIC_API_KEY=...
# ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
